---
import type { Locale } from '../../config/i18n';
import type { ArchiveTerm } from '../../lib/content/entries';
import { useTranslations } from '../../i18n/utils';

interface Props {
  categories: ArchiveTerm[];
  tags: ArchiveTerm[];
  total: number;
  locale: Locale;
}

const { categories, tags, total, locale } = Astro.props;
const t = useTranslations(locale);
const groups = [
  { kind: 'category', label: t('archive.filter.categories'), terms: categories },
  { kind: 'tag', label: t('archive.filter.tags'), terms: tags }
] as const;
---

<section
  data-archive-filter-root
  hidden
  class="surface-panel mb-6 space-y-4 p-4 sm:p-5"
  aria-label={t('archive.filter.label')}
>
  {groups.map((group) => (
    <fieldset>
      <legend class="sr-only">{group.label}</legend>
      <div class="sm:grid sm:grid-cols-[5.5rem_minmax(0,1fr)] sm:items-start sm:gap-4">
        <span aria-hidden="true" class="text-sm font-semibold text-foreground sm:pt-1">{group.label}</span>
        <div class="mt-2 flex min-w-0 flex-wrap gap-1.5 sm:mt-0">
          <button
            type="button"
            data-archive-filter-kind={group.kind}
            data-archive-filter-value=""
            aria-pressed="true"
            aria-controls="archive-results"
            class="inline-flex min-h-7 items-center gap-1 rounded-full border border-border bg-card px-2.5 py-0.5 text-xs font-medium text-muted-foreground transition-colors duration-200 hover:border-primary/30 hover:bg-muted hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/40 focus-visible:ring-offset-2 focus-visible:ring-offset-background aria-pressed:border-primary aria-pressed:bg-primary aria-pressed:text-primary-foreground aria-pressed:hover:bg-primary aria-pressed:hover:text-primary-foreground motion-reduce:transition-none"
          >
            {t('archive.filter.all')}
            <span class="tabular-nums opacity-70">{total}</span>
          </button>
          {group.terms.map((term) => (
            <button
              type="button"
              data-archive-filter-kind={group.kind}
              data-archive-filter-value={term.value}
              aria-pressed="false"
              aria-controls="archive-results"
              class="inline-flex min-h-7 items-center gap-1 rounded-full border border-border bg-card px-2.5 py-0.5 text-xs font-medium text-muted-foreground transition-colors duration-200 hover:border-primary/30 hover:bg-muted hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/40 focus-visible:ring-offset-2 focus-visible:ring-offset-background aria-pressed:border-primary aria-pressed:bg-primary aria-pressed:text-primary-foreground aria-pressed:hover:bg-primary aria-pressed:hover:text-primary-foreground motion-reduce:transition-none"
            >
              {term.value}
              <span class="tabular-nums opacity-60">{term.count}</span>
            </button>
          ))}
        </div>
      </div>
    </fieldset>
  ))}

  <div class="border-t border-border pt-4 text-sm text-muted-foreground">
    <p aria-live="polite" aria-atomic="true">
      {t('archive.results.prefix')} <strong data-archive-result-count class="font-semibold text-foreground">{total}</strong> {t('archive.results.suffix')}
    </p>
    <p data-archive-empty hidden class="mt-3 rounded-[var(--radius-control)] bg-muted px-4 py-3 text-foreground">
      {t('archive.filter.empty')}
    </p>
  </div>
</section>

<script>
  import '../../scripts/archive-filters.ts';
</script>
